---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, SITE } from '../consts';

// 78OK 最新 25 張藍色 banner 對應文案（前綴由下方模板自動加上「78OK 娛樂城」）
const banners = [
  ['01','首儲連續 3 天 立即領取 200% 獎勵'],['02','新會員註冊立即送 88 體驗金'],['03','EXpay 錢包 送 88 體驗金 官方信用合作安全無憂'],
  ['04','7 號會員日 每個月發放 7800 萬獎金'],['05','VIP 永不降級 升級禮金 388,888 生日禮金 58,888 月紅包 288,888'],['06','首儲第 7 天 領取大獎 15,888'],
  ['07','首儲第 30 天 領取大獎 18,888'],['08','每月 20-25 號 發放 5000 萬神秘獎金'],['09','每日返水 1% 獎勵無上限'],
  ['10','每天登入 領取簽到獎勵'],['11','虛擬幣存取款 尊享三重豪禮 EXpay 首存送 100%'],['12','EXpay 操作指南'],
  ['13','極速 ATM 存款 回饋 0.5%'],['14','預約取款 額外加送 1%'],['15','體育投注 連贏獎勵 8,888'],
  ['16','體育投注 日投注獎勵 2,888'],['17','體育投注 虧損保險 3%'],['18','真人娛樂 連贏獎勵 888,888'],
  ['19','真人娛樂 日投注獎勵 6,000'],['20','真人娛樂 虧損保險 17,888'],['21','電子捕魚棋牌 日投注獎勵 2,888'],
  ['22','電子捕魚棋牌 每日獎勵 3%'],['23','電子捕魚棋牌 虧損保險 5%'],['24','推廣賺錢 一次邀請終生陪伴 百萬佣金天天領'],
  ['25','BNG 獎金雨 7.6-9.27 好禮天天領'],
];

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
const fmt = (d) => d.toISOString().slice(0, 10);
const canonical = SITE.url + '/';

const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE.name,
  alternateName: SITE.brand,
  url: SITE.url,
  logo: new URL('/images/banner-01.webp', SITE.url).href,
  description: `${SITE.name}官方平台，提供體育投注、真人視訊、電子、捕魚與棋牌等多元遊戲。`,
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    url: SITE.lineUrl,
    availableLanguage: ['zh-Hant'],
  },
  sameAs: [SITE.lineUrl],
};
---
<!DOCTYPE html>
<html lang="zh-Hant-TW">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>78OK 娛樂城｜體育投注・真人・電子捕魚棋牌・每日優惠</title>
<meta name="description" content="78OK 娛樂城提供體育投注、真人、電子捕魚棋牌等多元遊戲，新會員註冊送 88 體驗金，首儲連續 3 天最高領 200%、每日返水回饋、EXpay 與虛擬幣快速存取款，24 小時客服全年不打烊。">
<link rel="canonical" href={canonical}>
<script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
<link rel="alternate" type="application/rss+xml" title={SITE.blogTitle} href="/rss.xml">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@600;700;800;900&family=Kanit:ital,wght@0,700;0,800;1,700;1,800&display=swap" rel="stylesheet">
<style is:global>
  *{box-sizing:border-box}
  body{margin:0;background:#eef7ff;font-family:"PingFang TC","Microsoft JhengHei","Noto Sans TC",system-ui,sans-serif;-webkit-font-smoothing:antialiased;color:#33475e}
  a{color:#1f7fe0;text-decoration:none}a:hover{color:#146fd6}
  .cinzel{font-family:Cinzel,serif}
  @keyframes you-mq{from{transform:translateX(0)}to{transform:translateX(-50%)}}
  .hero-wrap{position:relative;width:100%;aspect-ratio:1920/700;border-radius:20px;overflow:hidden;box-shadow:0 18px 50px rgba(60,130,220,.22);border:1px solid rgba(120,175,240,.35);background:#dcecfb}
  .slide{position:absolute;inset:0;opacity:0;transition:opacity .6s;z-index:1}
  .slide.active{opacity:1;z-index:2}
  .slide img{width:100%;height:100%;object-fit:cover;display:block}
  .hero-count{position:absolute;top:14px;left:16px;z-index:15;padding:5px 13px;border-radius:99px;background:rgba(20,60,120,.5);color:#dcecff;font-family:Kanit,sans-serif;font-style:italic;font-weight:700;font-size:13px;letter-spacing:1px}
  .hero-btn{position:absolute;top:50%;transform:translateY(-50%);z-index:20;width:44px;height:44px;border-radius:50%;border:none;cursor:pointer;background:rgba(255,255,255,.9);color:#1f7fe0;font-size:20px;box-shadow:0 4px 14px rgba(40,90,160,.2)}
  .hero-btn:hover{background:#fff}.hero-prev{left:16px}.hero-next{right:16px}
  .hero-dots{position:absolute;left:16px;right:16px;bottom:16px;display:flex;justify-content:center;flex-wrap:wrap;gap:8px;z-index:20}
  .hero-dots button{height:8px;width:8px;border-radius:99px;border:none;cursor:pointer;padding:0;background:rgba(255,255,255,.55);box-shadow:0 1px 4px rgba(0,0,0,.25);transition:all .3s}
  .hero-dots button.active{width:26px;background:#fff}
  .cat-tile{display:flex;flex-direction:column;align-items:center;gap:14px;padding:32px 18px;border-radius:18px;background:linear-gradient(180deg,#fff,#eef5fe);border:1px solid rgba(120,175,240,.3);box-shadow:0 6px 20px rgba(60,130,220,.1);transition:all .2s}
  .cat-tile:hover{transform:translateY(-5px);box-shadow:0 14px 32px rgba(60,130,220,.22);border-color:rgba(90,150,225,.6)}
  .cta-btn{display:inline-block;padding:16px 46px;border-radius:12px;font-size:18px;font-weight:800;letter-spacing:1px;color:#1f7fe0;background:#fff;box-shadow:0 10px 26px rgba(20,70,150,.3);transition:all .18s}
  .cta-btn:hover{transform:translateY(-2px);box-shadow:0 14px 32px rgba(20,70,150,.4);color:#146fd6}
  .p-card{display:flex;flex-direction:column;border-radius:18px;overflow:hidden;background:#fff;border:1px solid rgba(120,175,240,.3);box-shadow:0 6px 20px rgba(60,130,220,.1);transition:all .2s}
  .p-card:hover{transform:translateY(-5px);box-shadow:0 16px 34px rgba(60,130,220,.2);border-color:rgba(90,150,225,.55)}
  .p-card .th{aspect-ratio:16/9;overflow:hidden}.p-card .th img{width:100%;height:100%;object-fit:cover;display:block}
  .chip{align-self:flex-start;font-size:12px;font-weight:700;color:#0d4a94;background:linear-gradient(135deg,#bcdcff,#5cb4fb);padding:4px 12px;border-radius:99px}
  @media (max-width:900px){.cat-grid{grid-template-columns:repeat(2,1fr)!important}.service-grid{grid-template-columns:repeat(2,1fr)!important}.news-grid{grid-template-columns:1fr!important}h2{font-size:30px!important}}
</style>
</head>
<body>
<div style="min-height:100vh">

  <SiteHeader />

  <section style="background:linear-gradient(180deg,#f5faff,#dcecfb)" aria-label="主視覺輪播">
    <div style="max-width:1440px; margin:0 auto; padding:28px 32px 24px">
      <div class="hero-wrap" id="hero">
        {banners.map(([n, alt], i) => (
          <div class={`slide${i === 0 ? ' active' : ''}`}>
            <img src={`/images/banner-${n}.webp`} width="1920" height="700" loading={i === 0 ? 'eager' : 'lazy'} alt={`78OK 娛樂城 ${alt}`} />
          </div>
        ))}
        <div class="hero-count"><span id="heroCur">01</span> / 25</div>
        <button class="hero-btn hero-prev" id="heroPrev" aria-label="上一張">‹</button>
        <button class="hero-btn hero-next" id="heroNext" aria-label="下一張">›</button>
        <div class="hero-dots" id="heroDots" role="tablist" aria-label="輪播選擇"></div>
      </div>
    </div>
  </section>

  <section style="background:#fff; border-top:1px solid rgba(120,175,240,.25); border-bottom:1px solid rgba(120,175,240,.25)" aria-label="最新公告">
    <div style="max-width:1440px; margin:0 auto; padding:0 32px; display:flex; align-items:center; gap:16px; height:58px">
      <div style="flex:none; display:flex; align-items:center; gap:8px; padding:7px 16px; border-radius:99px; background:linear-gradient(180deg,#63b3fb,#1f7fe0); color:#fff; font-weight:700; font-size:14px; box-shadow:0 3px 10px rgba(31,127,224,.35)"><span style="width:6px;height:6px;border-radius:50%;background:#fff;display:block"></span> 最新公告</div>
      <div style="position:relative; flex:1; overflow:hidden; -webkit-mask-image:linear-gradient(90deg,transparent,#000 4%,#000 96%,transparent); mask-image:linear-gradient(90deg,transparent,#000 4%,#000 96%,transparent)">
        <div style="display:inline-flex; white-space:nowrap; animation:you-mq 32s linear infinite">
          <span style="display:inline-flex; align-items:center; gap:9px; padding:0 30px; font-size:15px; color:#3a5a7d; font-weight:500"><i style="width:5px;height:5px;border-radius:50%;background:#1f7fe0;display:inline-block"></i>新會員註冊即送 88 體驗金，簽到再領每日獎勵</span>
          <span style="display:inline-flex; align-items:center; gap:9px; padding:0 30px; font-size:15px; color:#3a5a7d; font-weight:500"><i style="width:5px;height:5px;border-radius:50%;background:#1f7fe0;display:inline-block"></i>首儲連續 3 天，最高領取 200% 獎勵</span>
          <span style="display:inline-flex; align-items:center; gap:9px; padding:0 30px; font-size:15px; color:#3a5a7d; font-weight:500"><i style="width:5px;height:5px;border-radius:50%;background:#1f7fe0;display:inline-block"></i>EXpay 與虛擬幣極速存取款，每筆再享回饋</span>
          <span style="display:inline-flex; align-items:center; gap:9px; padding:0 30px; font-size:15px; color:#3a5a7d; font-weight:500"><i style="width:5px;height:5px;border-radius:50%;background:#1f7fe0;display:inline-block"></i>體育・真人・電子捕魚棋牌，每日投注彩金天天領</span>
          <span style="display:inline-flex; align-items:center; gap:9px; padding:0 30px; font-size:15px; color:#3a5a7d; font-weight:500"><i style="width:5px;height:5px;border-radius:50%;background:#1f7fe0;display:inline-block"></i>新會員註冊即送 88 體驗金，簽到再領每日獎勵</span>
          <span style="display:inline-flex; align-items:center; gap:9px; padding:0 30px; font-size:15px; color:#3a5a7d; font-weight:500"><i style="width:5px;height:5px;border-radius:50%;background:#1f7fe0;display:inline-block"></i>首儲連續 3 天，最高領取 200% 獎勵</span>
          <span style="display:inline-flex; align-items:center; gap:9px; padding:0 30px; font-size:15px; color:#3a5a7d; font-weight:500"><i style="width:5px;height:5px;border-radius:50%;background:#1f7fe0;display:inline-block"></i>EXpay 與虛擬幣極速存取款，每筆再享回饋</span>
        </div>
      </div>
      <a href="/blog/categories/promotions/" style="flex:none; font-size:14px; font-weight:600; color:#1f7fe0; padding:6px 12px; border-radius:8px">更多 ›</a>
    </div>
  </section>

  <section id="games" style="max-width:1440px; margin:0 auto; padding:72px 32px 12px; text-align:center">
    <p class="cinzel" style="font-size:15px; letter-spacing:3px; margin:0 0 6px; color:#7aa8e6">TOP GAMES</p>
    <h2 style="font-size:42px; font-weight:900; margin:0 0 10px; letter-spacing:2px; color:#1e3f66">熱門遊戲分類</h2>
    <div style="display:flex; align-items:center; justify-content:center; gap:14px; margin-bottom:44px">
      <span style="width:60px; height:2px; background:linear-gradient(90deg,transparent,#1f7fe0)"></span><span style="color:#1258b8">◆</span><span style="width:60px; height:2px; background:linear-gradient(90deg,#1f7fe0,transparent)"></span>
    </div>
    <div class="cat-grid" style="display:grid; grid-template-columns:repeat(4,1fr); gap:20px">
      {[['體','體育投注','SPORTS'],['真','真人視訊','LIVE'],['電','電子遊戲','SLOTS'],['魚','捕魚遊戲','FISHING'],['棋','棋牌遊戲','POKER'],['彩','彩票遊戲','LOTTERY'],['競','電競投注','ESPORTS'],['全','全部遊戲','ALL GAMES']].map(([g,zh,en]) => (
        <a href="#" class="cat-tile">
          <span style="width:78px; height:78px; border-radius:20px; display:flex; align-items:center; justify-content:center; font-size:34px; font-weight:900; color:#fff; background:linear-gradient(160deg,#6dbcfd,#1f7fe0); box-shadow:0 6px 16px rgba(31,127,224,.4),inset 0 1px 2px rgba(255,255,255,.6)">{g}</span>
          <span style="font-size:18px; font-weight:700; color:#1e3f66">{zh}</span>
          <span class="cinzel" style="font-size:12px; letter-spacing:1.5px; color:#8aa6c8">{en}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ===== 最新文章（部落格自動帶入）===== -->
  <section style="max-width:1440px; margin:0 auto; padding:72px 32px 8px; text-align:center">
    <p class="cinzel" style="font-size:15px; letter-spacing:3px; margin:0 0 6px; color:#7aa8e6">LATEST POSTS</p>
    <h2 style="font-size:42px; font-weight:900; margin:0 0 10px; letter-spacing:2px; color:#1e3f66">最新文章</h2>
    <div style="display:flex; align-items:center; justify-content:center; gap:14px; margin-bottom:44px">
      <span style="width:60px; height:2px; background:linear-gradient(90deg,transparent,#1f7fe0)"></span><span style="color:#1258b8">◆</span><span style="width:60px; height:2px; background:linear-gradient(90deg,#1f7fe0,transparent)"></span>
    </div>
    <div class="news-grid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:26px; text-align:left">
      {posts.map((p) => (
        <a href={`/post/${p.slug}/`} class="p-card">
          <div class="th">{p.data.cover && <img src={p.data.cover} alt={p.data.coverAlt ?? p.data.title} loading="lazy" />}</div>
          <div style="padding:20px 22px 24px; display:flex; flex-direction:column; gap:10px">
            <span class="chip">{CATEGORIES[p.data.category]}</span>
            <h3 style="font-size:19px; font-weight:800; margin:2px 0; color:#1e3f66; line-height:1.4">{p.data.title}</h3>
            <p style="font-size:14px; color:#6b8ab0; margin:0">{p.data.description}</p>
            <div style="font-size:13px; color:#8aa6c8; margin-top:4px">{fmt(p.data.pubDate)} · {p.data.author}</div>
          </div>
        </a>
      ))}
    </div>
    <div style="margin-top:30px">
      <a href="/blog/" style="display:inline-block; font-size:15px; font-weight:600; color:#1f7fe0; padding:8px 4px; border-bottom:1px solid rgba(31,127,224,.4)">查看全部文章 →</a>
    </div>
  </section>

  <section id="service" style="margin-top:64px; background:linear-gradient(180deg,#ffffff,#e9f3fe); border-top:1px solid rgba(120,175,240,.25); padding:64px 32px">
    <div style="max-width:1440px; margin:0 auto; text-align:center">
      <p class="cinzel" style="font-size:15px; letter-spacing:3px; margin:0 0 6px; color:#8fb2de">QUALITY SERVICE</p>
      <h2 style="font-size:42px; font-weight:900; margin:0 0 10px; letter-spacing:2px; color:#1e3f66">優質服務</h2>
      <div style="display:flex; align-items:center; justify-content:center; gap:14px; margin-bottom:44px">
        <span style="width:60px; height:2px; background:linear-gradient(90deg,transparent,#1f7fe0)"></span><span style="color:#1f7fe0">◆</span><span style="width:60px; height:2px; background:linear-gradient(90deg,#1f7fe0,transparent)"></span>
      </div>
      <div class="service-grid" style="display:grid; grid-template-columns:repeat(4,1fr); gap:30px">
        {[['極速','快速出款免等待','FAST PAYOUT'],['安全','資金安全有保障','SECURE'],['全裝置','支援所有裝置','ALL DEVICES'],['24H','全年客服不打烊','SUPPORT']].map(([big,zh,en]) => (
          <div style="display:flex; flex-direction:column; align-items:center; gap:16px">
            <span class="kanit" style="width:128px; height:128px; border-radius:50%; display:flex; align-items:center; justify-content:center; background:radial-gradient(circle at 50% 38%,#3f9bf3,#1258b8); border:5px solid #bcdcff; box-shadow:0 12px 26px rgba(31,110,214,.3),inset 0 0 20px rgba(0,40,90,.35); font-size:28px; font-weight:900; color:#fff">{big}</span>
            <div><p style="font-size:18px; font-weight:700; color:#1e3f66; margin:0 0 3px">{zh}</p><p class="cinzel" style="font-size:12px; letter-spacing:1.5px; color:#8aa6c8; margin:0">{en}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="cta" style="position:relative; overflow:hidden; background:linear-gradient(135deg,#3f9bf3,#1258b8)">
    <div style="position:absolute; inset:0; background-image:radial-gradient(rgba(255,255,255,.16) 1px,transparent 1px); background-size:22px 22px; opacity:.6"></div>
    <div style="position:relative; max-width:900px; margin:0 auto; padding:72px 32px; text-align:center; color:#fff">
      <p class="cinzel" style="letter-spacing:3px; font-size:14px; margin:0 0 12px; color:rgba(255,255,255,.9)">JOIN 78OK</p>
      <h2 style="font-size:40px; font-weight:900; margin:0 0 14px; letter-spacing:1px; text-shadow:0 2px 8px rgba(10,50,110,.3)">立即加入，開啟你的遊戲之旅</h2>
      <p style="font-size:17px; line-height:1.7; margin:0 auto 32px; max-width:520px; color:rgba(255,255,255,.92)">30 秒完成註冊，新會員即送 88 體驗金，海量遊戲隨時隨地免費暢玩。</p>
      <a href="#" class="cta-btn">免費註冊 ›</a>
    </div>
  </section>

  <SiteFooter />
</div>

<script is:inline>
(function(){
  var slides = Array.prototype.slice.call(document.querySelectorAll('#hero .slide'));
  var dotsWrap = document.getElementById('heroDots');
  var curEl = document.getElementById('heroCur');
  var idx = 0, timer = null, N = slides.length;
  function pad(n){ return String(n+1).padStart(2,'0'); }
  slides.forEach(function(_,i){
    var b = document.createElement('button');
    b.setAttribute('role','tab'); b.setAttribute('aria-label','第 '+(i+1)+' 張');
    b.addEventListener('click', function(){ go(i); reset(); });
    dotsWrap.appendChild(b);
  });
  var dots = Array.prototype.slice.call(dotsWrap.children);
  function go(i){ idx=(i+N)%N; slides.forEach(function(s,j){ s.classList.toggle('active',j===idx); }); dots.forEach(function(d,j){ d.classList.toggle('active',j===idx); }); curEl.textContent=pad(idx); }
  function next(){ go(idx+1); }
  function reset(){ clearInterval(timer); timer=setInterval(next,5000); }
  document.getElementById('heroNext').addEventListener('click', function(){ next(); reset(); });
  document.getElementById('heroPrev').addEventListener('click', function(){ go(idx-1); reset(); });
  go(0); reset();
})();
</script>
</body>
</html>
